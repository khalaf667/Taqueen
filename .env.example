# Application
APP_ENV=development
APP_NAME=Taqueen
APP_URL=http://localhost:3000

# Backend
BACKEND_URL=http://localhost:5000
BACKEND_PORT=5000

# Frontend
FRONTEND_URL=http://localhost:3000
FRONTEND_PORT=3000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=taqueen_db
DB_USER=taqueen_user
DB_PASSWORD=taqueen_secure_password

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRY=7d

# Socket.io
SOCKET_CORS_ORIGIN=http://localhost:3000

# Mail (Optional)
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=465
MAIL_USER=your_email
MAIL_PASSWORD=your_password
MAIL_FROM=noreply@taqueen.io

# AWS S3 (Optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_BUCKET=taqueen-uploads

# Stripe (Payment)
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=

# Redis (Cache)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
