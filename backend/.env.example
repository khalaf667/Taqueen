# Environment
NODE_ENV=development

# Server
PORT=5000
HOST=0.0.0.0

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=taqueen_db
DB_USER=taqueen_user
DB_PASSWORD=taqueen_password
DB_POOL_SIZE=10

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRY=7d
JWT_REFRESH_SECRET=your_refresh_secret_key
JWT_REFRESH_EXPIRY=30d

# Socket.io
SOCKET_CORS_ORIGIN=http://localhost:3000
SOCKET_PING_INTERVAL=25000
SOCKET_PING_TIMEOUT=60000

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_BUCKET=taqueen-uploads

# Stripe
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Mail
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=465
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=noreply@taqueen.io

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# API
API_VERSION=v1
API_PREFIX=/api/v1
